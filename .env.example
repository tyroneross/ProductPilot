# Database (Neon Postgres)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000
# Optional: extra callback-URL origins, comma-separated (preview deploys, staging hosts).
# baseURL + the actual server listen origin are always trusted automatically.
BETTER_AUTH_TRUSTED_ORIGINS=

# Optional email delivery for verification links
RESEND_API_KEY=re_xxx
AUTH_FROM_EMAIL=ProductPilot <auth@example.com>

# Optional Google sign-in
GOOGLE_CLIENT_ID=google-client-id
GOOGLE_CLIENT_SECRET=google-client-secret

# Demo LLM — Groq (Llama 3.3 70B) for all unauthenticated users
GROQ_API_KEY=gsk_xxx

# Optional: Anthropic key for admin/testing
ANTHROPIC_API_KEY=sk-ant-xxx

# Observability (optional)
# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# Sentry DSN — leave blank to disable error reporting in this environment
SENTRY_DSN=
